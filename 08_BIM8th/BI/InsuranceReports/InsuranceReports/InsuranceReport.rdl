  <DataSources>
    <DataSource Name="InsuranceDW_DataSource">
      <DataSourceReference>InsuranceDW_DataSource</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>90df0812-a7b3-4ff9-95fa-80ba37a3c2ec</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>InsuranceDW_DataSource</DataSourceName>
        <CommandText>SELECT
    d.MonthName,
    d.YearValue,
    c.CategoryName,
    f.PoliciesCount,
    f.TotalPremium,
    f.SumInsured
FROM FactInsuranceBusiness f
INNER JOIN DimDate d
    ON f.DateID = d.DateID
INNER JOIN DimInsuranceCategory c
    ON f.CategoryID = c.CategoryID;</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="MonthName">
          <DataField>MonthName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="YearValue">
          <DataField>YearValue</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CategoryName">
          <DataField>CategoryName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PoliciesCount">
          <DataField>PoliciesCount</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TotalPremium">
          <DataField>TotalPremium</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="SumInsured">
          <DataField>SumInsured</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
